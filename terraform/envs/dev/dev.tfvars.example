# Copy to dev.tfvars (gitignored) and tweak. Everything has a default, so this file
# is optional - it just documents the knobs you'll most often touch.

aws_region  = "us-east-2"
environment = "dev"

# The upgrade lever. Bump ONE minor at a time and re-apply: 1.34 -> 1.35 -> 1.36
cluster_version = "1.34"

# Cost knobs
capacity_type     = "SPOT"
node_instance_types = ["t3.medium"]
node_desired_size = 3
node_min_size     = 2
node_max_size     = 4

# D2 networking. Private + single NAT = more to troubleshoot (default).
# Flip both for the cheapest public-node run.
node_subnet_tier   = "private"
enable_nat_gateway = true
single_nat_gateway = true

# Turn audit logging on before an upgrade to catch deprecated API usage server-side
# (costs a little CloudWatch). Left empty by default to stay cheap.
# enabled_cluster_log_types = ["audit", "api"]

# Fold the planted gotchas into `terraform apply`, or leave false and run `make seed`.
enable_planted_gotchas = false

# After you upgrade the control plane, roll the nodes by setting this to the new minor.
# node_version = "1.35"
