# Copy to prod.tfvars (gitignored) and tweak. Prod exists to prove the module composes
# and to exercise a prod-style pipeline - not to run 24/7. Apply ONE env at a time
# (dev + prod together = 2x control plane cost).

aws_region  = "us-east-2"
environment = "prod"

cluster_version = "1.34"

# Prod realism: steadier capacity. SPOT is still fine for a throwaway test.
capacity_type       = "ON_DEMAND"
node_instance_types = ["t3.medium"]
node_desired_size   = 3
node_min_size       = 2
node_max_size       = 4

# Prod-style networking
node_subnet_tier   = "private"
enable_nat_gateway = true
single_nat_gateway = true

# Recommended before a prod upgrade: audit logging on to catch deprecated APIs server-side.
enabled_cluster_log_types = ["audit", "api"]

# Lock the public API endpoint down in real prod (replace with your office/VPN CIDRs).
# public_access_cidrs = ["203.0.113.0/24"]

enable_planted_gotchas = false
